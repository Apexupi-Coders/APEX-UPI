<configuration>
  <springProperty scope="context" name="log.path" source="logging.file.path"/>
  
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} [%X{txnId:-}] [%X{state:-}] %marker %msg%n</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>

  <logger name="com.apexupi.psp_switch.orchestrator" level="DEBUG"/>
  <logger name="com.apexupi.psp_switch.adapter" level="DEBUG"/>
</configuration>
