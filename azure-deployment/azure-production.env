# =============================================================================
# APEX-UPI — Azure Production Bare-Metal Configuration
# Distributed across 3 VMs using Private 10.0.0.x Networking
# =============================================================================

# ─── Kafka (Hosted on VM 1) ───────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=10.0.0.4:9092

KAFKA_TOPIC_PAYMENT_REQUESTS=psp.payment.initiate.request
KAFKA_TOPIC_NPCI_OUTBOUND=npci.outbound.request
KAFKA_TOPIC_NPCI_RESPONSE=npci.inbound.response
KAFKA_TOPIC_SWITCH_COMPLETED=psp.switch.completed.events

# ─── PostgreSQL Global Credentials ────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_USER=postgres
DB_PASS=postgres

# ─── VM 1: PSP Switch Databases ───────────────────────────────────────────────
POSTGRES_URL_INGRESS=jdbc:postgresql://10.0.0.4:5432/tpap_ingress
POSTGRES_URL_ORCHESTRATOR=jdbc:postgresql://10.0.0.4:5432/orchestrator
POSTGRES_URL_EGRESS=jdbc:postgresql://10.0.0.4:5432/egress_db
POSTGRES_URL_LEDGER=jdbc:postgresql://10.0.0.4:5432/ledger_db

# ─── VM 1: Redis ──────────────────────────────────────────────────────────────
REDIS_HOST=10.0.0.4
REDIS_PORT=6379

# ─── VM 3: CBS Databases ──────────────────────────────────────────────────────
DEBIT_DB_URL=jdbc:postgresql://10.0.0.6:5432/cbs_debit
CREDIT_DB_URL=jdbc:postgresql://10.0.0.6:5432/cbs_credit

# ─── Network Routing (Cross-VM HTTP) ──────────────────────────────────────────
# PSP (VM 1) talks to NPCI (VM 2)
NPCI_BASE_URL=http://10.0.0.5:8082

# NPCI (VM 2) sends webhooks back to PSP (VM 1)
PSP_CALLBACK_URL=http://10.0.0.4:8084

# NPCI (VM 2) forwards transactions to CBS (VM 3)
BANKSWITCH_HOST=http://10.0.0.6:8083

# ─── Security & Timeouts ──────────────────────────────────────────────────────
NPCI_ORG_ID=DEMOPSP
NPCI_TIMEOUT_SECONDS=30
NPCI_VERIFY_SIGNATURE=false
PSP_ID=DEMOPSP

CRYPTO_ENABLED=true
CRYPTO_SECRET_KEY=PSPSwitch2024DemoKey1234567890AB
LEDGER_CRYPTO_ENABLED=true
LEDGER_CRYPTO_KEY=PSPSwitch2024DemoKey1234567890AB
